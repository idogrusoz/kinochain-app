{
  "expo": {
    "name": "Kinochain",
    "slug": "kinochain-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.idogrusoz.kinochainapp",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0E10"
      },
      "package": "com.idogrusoz.kinochainapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111113",
          "image": "./assets/icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/icon.png",
            "backgroundColor": "#111113",
            "resizeMode": "contain"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "41fe5f26-94f3-48fa-8fe9-29a7080e59fd"
      }
    },
    "experiments": {
      "tsconfigPaths": true
    }
  }
}
