{
  "expo": {
    "name": "Kinochain",
    "slug": "kinochain",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rightword.kinochain",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0E10"
      },
      "package": "com.rightword.kinochain"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111113",
          "image": "./assets/icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/icon.png",
            "backgroundColor": "#111113",
            "resizeMode": "contain"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "10395d9e-c905-44e2-89a2-a125d1c61d91"
      }
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "owner": "rightword"
  }
}
