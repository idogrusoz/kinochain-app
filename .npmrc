# Security hardening for installs.
# Block dependency lifecycle scripts (preinstall/install/postinstall) — the
# primary execution vector used by npm supply-chain attacks. This Expo project
# has no packages that rely on install scripts, so this is safe here.
ignore-scripts=true

# Pin the registry explicitly (avoids accidental use of a misconfigured mirror).
registry=https://registry.npmjs.org/
