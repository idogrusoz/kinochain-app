# TMDB API key (v3). The app calls TMDB directly on-device; this key is embedded
# at build time via EXPO_PUBLIC_*. It is read-only and revocable — rotate it if
# it is ever abused. Get a key at https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here

# Aptabase app key for anonymous, aggregate analytics (open-source, iOS+Android).
# Create a free project at https://aptabase.com (or self-host) to get a key like
# A-EU-0000000000 / A-US-0000000000. Leave unset to disable analytics entirely —
# the app runs unchanged without it. The key prefix selects the region; for a
# self-hosted server, also pass `host` in src/services/analytics.ts.
EXPO_PUBLIC_APTABASE_KEY=your_aptabase_app_key_here
