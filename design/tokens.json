{
  "$meta": {
    "name": "Kinochain design tokens",
    "version": "0.2.0",
    "updated": "2026-06-28",
    "description": "Platform-agnostic design tokens for Kinochain. Values are the source of truth for React Native today and for a future Swift/Kotlin port. Sizes are unitless and map to pt (iOS) / dp (Android)."
  },
  "color": {
    "background": { "base": "#0E0E10", "surface": "#141414", "surfaceRaised": "#1A1A1B" },
    "border": { "hairline": "#2C2C2E", "divider": "#242426", "gold": "#C9A24A" },
    "text": { "primary": "#F2EEE4", "secondary": "#9A968C", "muted": "#56544D", "onGold": "#0E0E10" },
    "gold": { "base": "#C9A24A", "bright": "#E6CC8A", "deep": "#8A7233", "keyline": "#6F5B29", "tintBg": "#1C160A", "deepText": "#15120A" },
    "brass": { "type": "linear-gradient", "angle": 145, "stops": ["#F0DCA6", "#C9A24A@58%", "#B8923E"], "keyline": "#8A7233", "_use": "primary CTA + selected difficulty (brushed-metal button); dark text uses gold.deepText" },
    "logoGradient": { "type": "linear-gradient", "direction": "topLeft->bottomRight", "stops": ["#F4E1AC", "#C9A24A@55%", "#8A7233"], "_use": "the film-strip K mark" },
    "tmdbAttribution": ["#90CEA1", "#3CBEC9", "#00B3E5"],
    "icon": { "default": "#9A968C", "muted": "#6F6C64", "gold": "#C9A24A" },
    "_usage": "Gold is reserved for MEANING only: the goal/target, progress, and primary actions. Never use gold as a large fill or for decoration."
  },
  "typography": {
    "family": {
      "display": "Space Grotesk",
      "text": "Inter",
      "iosNative": "SF Pro (system-ui)",
      "androidNative": "Roboto / Inter"
    },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "style": {
      "wordmark": { "family": "display", "size": 18, "weight": 700, "tracking": 1.0, "case": "upper" },
      "heroTitle": { "family": "display", "size": 22, "weight": 600, "lineHeight": 1.05, "iosTextStyle": "title2" },
      "statNumber": { "family": "display", "size": 22, "weight": 600 },
      "statLarge": { "family": "display", "size": 34, "weight": 700, "_use": "win-screen moves/time" },
      "celebration": { "family": "display", "size": 25, "weight": 700, "_use": "win-screen headline" },
      "buttonPrimary": { "family": "display", "size": 16, "weight": 600, "tracking": 1.0, "case": "upper" },
      "actorName": { "family": "display", "size": 15, "weight": 500 },
      "listTitle": { "family": "text", "size": 15, "weight": 500, "iosTextStyle": "headline" },
      "body": { "family": "text", "size": 12, "weight": 400, "lineHeight": 1.4, "iosTextStyle": "footnote" },
      "overline": { "family": "text", "size": 11, "weight": 500, "tracking": 1.2, "case": "upper", "iosTextStyle": "caption2" },
      "microLabel": { "family": "text", "size": 9, "weight": 500, "tracking": 1.0, "case": "upper" }
    },
    "_note": "Custom fonts do not auto-scale with Dynamic Type. Map each style to the listed iosTextStyle and scale relative to it; never render below 11pt."
  },
  "spacing": { "xxs": 4, "xs": 6, "sm": 8, "md": 12, "lg": 16, "xl": 22, "screenMargin": 16 },
  "radius": { "thumb": 4, "control": 12, "card": 14, "pill": 999 },
  "border": { "hairline": 1, "accent": 1 },
  "size": { "minTapTarget": 44, "currentNode": 42, "actorPortrait": 54, "posterThumb": { "w": 34, "h": 48 } },
  "motion": {
    "durationFast": 180,
    "durationBase": 240,
    "easing": "ease-out",
    "haptics": { "rowTap": "light", "nodeLockIn": "medium", "win": "success" }
  }
}
